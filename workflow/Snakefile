# ChIP-seq / CUT&Tag Snakemake Pipeline (no-input by default)
# =================================================================

import csv
import os
import sys

# ---------------------------------------------------------------------------
# 1. Load configuration
# ---------------------------------------------------------------------------
configfile: "config/config.yaml"

OUTDIR = config.get("outdir", "results")
THREADS = config.get("threads", 8)
MAPQ = config.get("mapq", 30)
BINSIZE = config.get("binsize", 10)
REMOVE_DUP = config.get("remove_dup", "auto")
TRIM = str(config.get("trim", True)).lower()
EXTEND_READS = str(config.get("extend_reads", "auto"))
USE_CONTROL = config.get("use_control", False)
MULTIQC = config.get("multiqc", True)
SCRIPT = os.path.abspath("scripts/chipseq.sh")

# ---------------------------------------------------------------------------
# 2. Load and validate sample sheet
# ---------------------------------------------------------------------------
SAMPLE_TSV = config.get("samples")
if not SAMPLE_TSV:
    sys.exit("ERROR: config.yaml must set 'samples' to the TSV path.")
if not os.path.isfile(SAMPLE_TSV):
    sys.exit(f"ERROR: sample sheet not found: {SAMPLE_TSV}")

SAMPLES: list[dict] = []
SEEN_IDS: set[str] = set()

with open(SAMPLE_TSV) as fh:
    reader = csv.DictReader(fh, delimiter="\t")
    fieldnames = reader.fieldnames or []

    required = [
        "sample", "fastq_1", "layout", "assay",
        "target", "peak_mode", "genome", "bowtie2_index",
    ]
    for col in required:
        if col not in fieldnames:
            sys.exit(f"ERROR: sample sheet missing required column: {col!r}")

    for i, row in enumerate(reader, start=2):
        # csv.DictReader returns None for empty cells — coerce to ""
        sid   = (row.get("sample") or "").strip()
        fq1   = (row.get("fastq_1") or "").strip()
        fq2   = (row.get("fastq_2") or "").strip()
        lo    = (row.get("layout") or "").strip().upper()
        assay = (row.get("assay") or "").strip().lower()
        tgt   = (row.get("target") or "").strip()
        pmode = (row.get("peak_mode") or "").strip().lower()
        gnm   = (row.get("genome") or "").strip()
        bt2   = (row.get("bowtie2_index") or "").strip()
        ctrl  = (row.get("control_bam") or "").strip()

        # --- validation ---
        if not sid:
            sys.exit(f"ERROR: row {i} in sample sheet has empty 'sample'")
        if sid in SEEN_IDS:
            sys.exit(f"ERROR: duplicate sample ID: {sid!r}")
        SEEN_IDS.add(sid)

        if not fq1:
            sys.exit(f"ERROR: sample {sid!r} has empty 'fastq_1'")
        if lo not in ("PE", "SE"):
            sys.exit(f"ERROR: sample {sid!r}: layout must be PE or SE, got {lo!r}")
        if lo == "PE" and not fq2:
            sys.exit(f"ERROR: sample {sid!r}: PE layout requires 'fastq_2'")
        if assay not in ("chipseq", "cuttag"):
            sys.exit(f"ERROR: sample {sid!r}: assay must be chipseq or cuttag, got {assay!r}")
        if pmode not in ("narrow", "broad"):
            sys.exit(f"ERROR: sample {sid!r}: peak_mode must be narrow or broad, got {pmode!r}")
        if not bt2:
            sys.exit(f"ERROR: sample {sid!r} has empty 'bowtie2_index'")

        # control is only active when use_control is true
        control = ""
        if USE_CONTROL and ctrl:
            control = ctrl

        SAMPLES.append({
            "id":       sid,
            "fq1":      fq1,
            "fq2":      fq2,
            "layout":   lo,
            "assay":    assay,
            "target":   tgt,
            "peak_mode": pmode,
            "genome":   gnm,
            "bt2_idx":  bt2,
            "control":  control,
            "outdir":   os.path.join(OUTDIR, sid),
        })

SAMPLE_IDS  = [s["id"] for s in SAMPLES]
SAMPLE_MAP  = {s["id"]: s for s in SAMPLES}

# peak extension: narrowPeak or broadPeak
PEAK_EXT = {"narrow": "narrowPeak", "broad": "broadPeak"}

# map sample sheet "assay" column to chipseq.sh --tech value
ASSAY_TO_TECH = {"chipseq": "chip", "cuttag": "cuttag"}


# ---------------------------------------------------------------------------
# 3. Helpers
# ---------------------------------------------------------------------------
def _sample_inputs(wildcards):
    s = SAMPLE_MAP[wildcards.sample]
    files = [s["fq1"]]
    if s["layout"] == "PE" and s["fq2"]:
        files.append(s["fq2"])
    if s["control"]:
        files.append(s["control"])
    return files



# ---------------------------------------------------------------------------
# 4. Targets
# ---------------------------------------------------------------------------
rule all:
    input:
        done    = expand(
            "{outdir}/{sample}/logs/{sample}.pipeline.done",
            outdir=OUTDIR,
            sample=SAMPLE_IDS,
        ),
        bigwig  = expand(
            "{outdir}/{sample}/03_bigwig/{sample}.CPM.bw",
            outdir=OUTDIR,
            sample=SAMPLE_IDS,
        ),
        peaks   = expand(
            "{outdir}/{sample}/04_peaks/{sample}",
            outdir=OUTDIR,
            sample=SAMPLE_IDS,
        ),
        multiqc = [f"{OUTDIR}/multiqc/multiqc_report.html"] if MULTIQC else [],


# ---------------------------------------------------------------------------
# 5. Run a single sample through chipseq.sh
# ---------------------------------------------------------------------------
rule run_sample:
    output:
        done   = f"{OUTDIR}/{{sample}}/logs/{{sample}}.pipeline.done",
        bigwig = f"{OUTDIR}/{{sample}}/03_bigwig/{{sample}}.CPM.bw",
        peaks  = directory(f"{OUTDIR}/{{sample}}/04_peaks/{{sample}}"),
    input:
        _sample_inputs,
    log:
        f"{OUTDIR}/{{sample}}/logs/{{sample}}.snakemake.log",
    threads: THREADS,
    conda:
        "envs/chipseq.yml",
    params:
        sample     = "{sample}",
        fq1        = lambda wc: SAMPLE_MAP[wc.sample]["fq1"],
        fq2        = lambda wc: SAMPLE_MAP[wc.sample]["fq2"],
        layout     = lambda wc: SAMPLE_MAP[wc.sample]["layout"],
        tech       = lambda wc: ASSAY_TO_TECH[SAMPLE_MAP[wc.sample]["assay"]],
        peak_mode  = lambda wc: SAMPLE_MAP[wc.sample]["peak_mode"],
        genome     = lambda wc: SAMPLE_MAP[wc.sample]["genome"],
        bt2_idx    = lambda wc: SAMPLE_MAP[wc.sample]["bt2_idx"],
        control    = lambda wc: SAMPLE_MAP[wc.sample]["control"],
        mapq       = MAPQ,
        binsize    = BINSIZE,
        remove_dup = REMOVE_DUP,
        ext_len    = EXTEND_READS,
        trim_flag  = TRIM,
        script     = SCRIPT,
        outdir     = lambda wc: f"{OUTDIR}/{wc.sample}",
    shell:
        """
        set -euo pipefail

        mkdir -p $(dirname {log})

        CMD=(
            bash {params.script}
            -s {params.sample:q}
            -x {params.bt2_idx:q}
            -g {params.genome:q}
            -o {params.outdir:q}
            -p {threads}
            --mapq {params.mapq}
            --binSize {params.binsize}
            --removeDup {params.remove_dup:q}
            --extendReads {params.ext_len:q}
            --tech {params.tech:q}
            --peakMode {params.peak_mode:q}
        )

        if [[ "{params.layout}" == "PE" ]]; then
            CMD+=(--pe -r1 {params.fq1:q} -r2 {params.fq2:q})
        else
            CMD+=(--se -r1 {params.fq1:q})
        fi

        if [[ "{params.trim_flag}" == "true" ]]; then
            CMD+=(--trim)
        else
            CMD+=(--no-trim)
        fi

        if [[ -n "{params.control}" ]]; then
            CMD+=(--control_bam {params.control:q})
        fi

        echo ">>> [Snakemake] ${{CMD[@]}}"
        "${{CMD[@]}}" 2>&1 | tee {log}
        RET=${{PIPESTATUS[0]}}

        if [[ $RET -ne 0 ]]; then
            echo "ERROR: chipseq.sh exited with code $RET" >&2
            exit $RET
        fi

        # Verify all expected outputs exist. BigWig is tracked by Snakemake
        # (fixed path in output list). Peak is checked here because its
        # extension varies per sample.
        PEAK_SUFFIX="narrowPeak"
        [[ "{params.peak_mode}" == "broad" ]] && PEAK_SUFFIX="broadPeak"
        EXPECTED_PEAK="{params.outdir}/04_peaks/{params.sample}/{params.sample}_peaks.$PEAK_SUFFIX"
        if [[ ! -f "$EXPECTED_PEAK" ]]; then
            echo "ERROR: chipseq.sh completed but expected peak file not found: $EXPECTED_PEAK" >&2
            exit 1
        fi

        if [[ ! -s {output.bigwig:q} ]]; then
            echo "ERROR: expected bigWig not found or empty: {output.bigwig}" >&2
            exit 1
        fi

        touch {output.done}
        """


# ---------------------------------------------------------------------------
# 6. MultiQC aggregation
# ---------------------------------------------------------------------------
if MULTIQC:

    rule multiqc:
        input:
            [f"{OUTDIR}/{sid}/logs/{sid}.pipeline.done" for sid in SAMPLE_IDS],
        output:
            f"{OUTDIR}/multiqc/multiqc_report.html",
        log:
            f"{OUTDIR}/logs/multiqc.log",
        params:
            outdir = lambda w, output: os.path.dirname(os.path.dirname(output[0])),
        conda:
            "envs/chipseq.yml",
        shell:
            """
            command -v multiqc >/dev/null 2>&1 || {{
                echo "ERROR: multiqc not found. Install it or set multiqc: false in config.yaml." >&2
                exit 1
            }}
            mkdir -p {params.outdir}/logs {params.outdir}/multiqc
            multiqc {params.outdir} -o {params.outdir}/multiqc 2>&1 | tee {log}
            """
