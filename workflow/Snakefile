# ChIP-seq / CUT&Tag Snakemake Pipeline
# ======================================
# Entry point for the modular Snakemake pipeline suite.
# Sample sheet parsing, config loading, and assay dispatch happen here.
# Executable rules live in workflow/rules/*.smk.
# Policy functions live in workflow/rules/chipseq.smk and cuttag.smk.

import os
import sys
import re

# Make scripts/ importable from the repo root.
# workflow.basedir is the absolute path to the Snakefile directory.
sys.path.insert(
    0, os.path.join(os.path.dirname(workflow.basedir), "scripts")
)
from validate_samples import (
    validate_config,
    load_and_validate_samples,
)


# ---------------------------------------------------------------------------
# 1. Load configuration
# ---------------------------------------------------------------------------

configfile: "config/config.yaml"

VALIDATED_CONFIG = validate_config(config)

OUTDIR      = VALIDATED_CONFIG["outdir"]
THREADS     = VALIDATED_CONFIG["threads"]
MAPQ        = VALIDATED_CONFIG["mapq"]
MAPQ_TAG    = f"mapq{MAPQ}"
BINSIZE     = VALIDATED_CONFIG["binsize"]
TRIM        = VALIDATED_CONFIG["trim"]
USE_CONTROL = VALIDATED_CONFIG["use_control"]
MULTIQC     = VALIDATED_CONFIG["multiqc"]
GENOME_RESOURCES = VALIDATED_CONFIG.get("genome_resources", {})


# ---------------------------------------------------------------------------
# 2. Helper functions
# ---------------------------------------------------------------------------

def _normalize_genome(genome):
    """Resolve effective genome size from genome_resources or legacy fallback.

    Prefers configured effective_genome_size in genome_resources.
    Falls back to legacy mm10/mm39 → mm, hg19/hg38 → hs mapping only
    when no resource entry exists for the genome.
    """
    resource = GENOME_RESOURCES.get(genome, {})
    egs = resource.get("effective_genome_size")
    if egs is not None and egs != "":
        return str(egs)

    # Legacy fallback — only when no genome_resource entry exists
    if genome in ("mm10", "mm39"):
        return "mm"
    if genome in ("hg19", "hg38"):
        return "hs"
    return genome


# ---------------------------------------------------------------------------
# 3. Sample sheet loading (validated via shared helpers)
# ---------------------------------------------------------------------------

SAMPLES = load_and_validate_samples(
    VALIDATED_CONFIG["samples"],
    use_control=USE_CONTROL,
)

# --- Derived ID lists ---
SAMPLE_MAP           = {s["id"]: s for s in SAMPLES}
ALL_SAMPLE_IDS       = [s["id"] for s in SAMPLES]
TREATMENT_SAMPLE_IDS = [
    s["id"] for s in SAMPLES if s["role"] == "treatment"
]
# use_control gates both FASTQ-based control_sample and external control_bam.
# When false, control rows are not required as rule-all targets and
# control_sample / control_bam are silently ignored.
ACTIVE_SAMPLE_IDS = (
    ALL_SAMPLE_IDS if USE_CONTROL else TREATMENT_SAMPLE_IDS
)
CONTROL_SAMPLE_IDS   = [
    s["id"] for s in SAMPLES if s["role"] == "control"
]


# ---------------------------------------------------------------------------
# 3a. Stage 3 QC configuration and genome resource helpers
# ---------------------------------------------------------------------------

QC_CONFIG = VALIDATED_CONFIG.get("qc", {
    "blacklist_filter": True,
    "frip": True,
    "summary": True,
})

# Samples with a configured blacklist path (resource-gated blacklist filtering)
BLACKLIST_SAMPLES = [
    s for s in TREATMENT_SAMPLE_IDS
    if GENOME_RESOURCES.get(SAMPLE_MAP[s]["genome"], {}).get("blacklist", "")
]


def get_genome_resource(sample, key, default=""):
    """Return a genome resource path for a sample, or *default* if unset."""
    genome = SAMPLE_MAP[sample]["genome"]
    return GENOME_RESOURCES.get(genome, {}).get(key, default)


def has_genome_resource(sample, key):
    """Return True if a non-empty genome resource is configured for *sample*."""
    return bool(get_genome_resource(sample, key, ""))


# ---------------------------------------------------------------------------
# 4. Assay policy functions (no rules — define-only files)
# ---------------------------------------------------------------------------

include: "rules/chipseq.smk"
include: "rules/cuttag.smk"


# ---------------------------------------------------------------------------
# 5. Dispatch wrappers — wire assay-specific policy to generic names
# ---------------------------------------------------------------------------

def get_remove_dup(wildcards):
    """Return "yes" or "no" for duplicate removal, dispatched by assay."""
    s = SAMPLE_MAP[wildcards.sample]
    if s["assay"] == "chipseq":
        return get_remove_dup_chipseq(wildcards)
    else:
        return get_remove_dup_cuttag(wildcards)


def get_macs3_args(wildcards):
    """Return MACS3 arguments string, dispatched by assay."""
    s = SAMPLE_MAP[wildcards.sample]
    if s["assay"] == "chipseq":
        return get_macs3_args_chipseq(wildcards)
    else:
        return get_macs3_args_cuttag(wildcards)


def get_extend_reads(wildcards):
    """Return bamCoverage extension arguments, dispatched by assay."""
    s = SAMPLE_MAP[wildcards.sample]
    if s["assay"] == "chipseq":
        return get_extend_reads_chipseq(wildcards)
    else:
        return get_extend_reads_cuttag(wildcards)


# ---------------------------------------------------------------------------
# 6. MACS3 input resolution — tracks control dependencies
# ---------------------------------------------------------------------------

def _macs3_inputs(wildcards):
    """Return input list for macs3_callpeak.

    Elements: [treatment_final.bam, treatment_final.bam.bai, ...optional_control]
    - treatment final.bam + final.bam.bai are always included.
    - use_control gates both FASTQ-based control_sample and external control_bam.
      When false, control_sample and control_bam are silently ignored.
    """
    s = SAMPLE_MAP[wildcards.sample]
    sid = wildcards.sample
    inputs = [
        f"{OUTDIR}/{sid}/02_align/{sid}.final.bam",
        f"{OUTDIR}/{sid}/02_align/{sid}.final.bam.bai",
    ]
    if USE_CONTROL:
        if s.get("control_sample"):
            cs = s["control_sample"]
            inputs.append(
                f"{OUTDIR}/{cs}/02_align/{cs}.final.bam"
            )
        elif s.get("control_bam"):
            inputs.append(s["control_bam"])
    return inputs


# ---------------------------------------------------------------------------
# 7. Default target — rule all
#    Defined BEFORE executable rule includes to remain the default target.
# ---------------------------------------------------------------------------

rule all:
    input:
        done    = expand(
            "{outdir}/{sample}/logs/{sample}.pipeline.done",
            outdir=OUTDIR,
            sample=TREATMENT_SAMPLE_IDS,
        ),
        bigwig  = expand(
            "{outdir}/{sample}/03_bigwig/{sample}.CPM.bw",
            outdir=OUTDIR,
            sample=ACTIVE_SAMPLE_IDS,
        ),
        peaks   = expand(
            "{outdir}/{sample}/04_peaks/{sample}",
            outdir=OUTDIR,
            sample=TREATMENT_SAMPLE_IDS,
        ),
        multiqc = (
            [f"{OUTDIR}/multiqc/multiqc_report.html"] if MULTIQC else []
        ),
        # Stage 3 QC: peak counts (enabled when summary is true)
        peak_counts = (
            expand(
                "{outdir}/{sample}/01_qc/{sample}.peak_counts.tsv",
                outdir=OUTDIR,
                sample=TREATMENT_SAMPLE_IDS,
            )
            if QC_CONFIG.get("summary", True) else []
        ),
        # Stage 3 QC: FRiP (enabled when frip or summary is true)
        frip = (
            expand(
                "{outdir}/{sample}/01_qc/{sample}.frip.tsv",
                outdir=OUTDIR,
                sample=TREATMENT_SAMPLE_IDS,
            )
            if (QC_CONFIG.get("frip", True) or QC_CONFIG.get("summary", True))
            else []
        ),
        # Stage 3 QC: per-sample summary (enabled when summary is true)
        qc_summary = (
            expand(
                "{outdir}/{sample}/01_qc/{sample}.qc_summary.tsv",
                outdir=OUTDIR,
                sample=TREATMENT_SAMPLE_IDS,
            )
            if QC_CONFIG.get("summary", True) else []
        ),
        # Stage 3 QC: blacklist-filtered BAM (only for samples with a blacklist)
        bl_bam = (
            expand(
                "{outdir}/{sample}/02_align/{sample}.blacklist_filtered.bam",
                outdir=OUTDIR,
                sample=BLACKLIST_SAMPLES,
            )
            if QC_CONFIG.get("blacklist_filter", True) and BLACKLIST_SAMPLES
            else []
        ),
        bl_bai = (
            expand(
                "{outdir}/{sample}/02_align/{sample}.blacklist_filtered.bam.bai",
                outdir=OUTDIR,
                sample=BLACKLIST_SAMPLES,
            )
            if QC_CONFIG.get("blacklist_filter", True) and BLACKLIST_SAMPLES
            else []
        ),
        # Stage 3 QC: blacklist-filtered peaks (per peak_mode for samples with a blacklist)
        bl_peaks_narrow = (
            expand(
                "{outdir}/{sample}/04_peaks/{sample}_blacklist_filtered/{sample}_peaks.blacklist_filtered.narrowPeak",
                outdir=OUTDIR,
                sample=[s for s in BLACKLIST_SAMPLES if SAMPLE_MAP[s]["peak_mode"] == "narrow"],
            )
            if QC_CONFIG.get("blacklist_filter", True) and [
                s for s in BLACKLIST_SAMPLES if SAMPLE_MAP[s]["peak_mode"] == "narrow"
            ]
            else []
        ),
        bl_peaks_broad = (
            expand(
                "{outdir}/{sample}/04_peaks/{sample}_blacklist_filtered/{sample}_peaks.blacklist_filtered.broadPeak",
                outdir=OUTDIR,
                sample=[s for s in BLACKLIST_SAMPLES if SAMPLE_MAP[s]["peak_mode"] == "broad"],
            )
            if QC_CONFIG.get("blacklist_filter", True) and [
                s for s in BLACKLIST_SAMPLES if SAMPLE_MAP[s]["peak_mode"] == "broad"
            ]
            else []
        ),
        # Stage 3 QC: project-level aggregated summary
        stage3_summary = (
            [f"{OUTDIR}/multiqc/stage3_qc_summary.tsv"]
            if QC_CONFIG.get("summary", True) and TREATMENT_SAMPLE_IDS else []
        ),


# ---------------------------------------------------------------------------
# 8. Executable rule files
# ---------------------------------------------------------------------------

include: "rules/common.smk"
include: "rules/peaks.smk"
include: "rules/qc.smk"
