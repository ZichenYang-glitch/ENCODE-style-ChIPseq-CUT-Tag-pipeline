import re

# Make scripts/ importable from the repo root.
# workflow.basedir is the absolute path to the Snakefile directory.
sys.path.insert(
    0, os.path.join(os.path.dirname(workflow.basedir), "scripts")
)
from validate_samples import (
    validate_config,
    load_and_validate_samples,
    validate_picard_reference_resources,
    validate_tss_annotation_resources,
)
from histone_utils import classify_histone_target


# ---------------------------------------------------------------------------
# 1. Load configuration
# ---------------------------------------------------------------------------

configfile: "config/config.yaml"

VALIDATED_CONFIG = validate_config(config)

OUTDIR      = VALIDATED_CONFIG["outdir"]
THREADS     = VALIDATED_CONFIG["threads"]
MAPQ        = VALIDATED_CONFIG["mapq"]
MAPQ_TAG    = f"mapq{MAPQ}"
BINSIZE     = VALIDATED_CONFIG["binsize"]
TRIM        = VALIDATED_CONFIG["trim"]
USE_CONTROL = VALIDATED_CONFIG["use_control"]
MULTIQC     = VALIDATED_CONFIG["multiqc"]
STAGE4B     = VALIDATED_CONFIG.get("stage4b", True)
STAGE5      = VALIDATED_CONFIG.get("stage5", False)
IDR_SETTINGS = VALIDATED_CONFIG.get("idr", {})
IDR_THRESHOLD = float(IDR_SETTINGS.get("threshold", 0.05))
IDR_RANK = str(IDR_SETTINGS.get("rank", "p.value"))
IDR_SEED = int(IDR_SETTINGS.get("seed", 42))
GENOME_RESOURCES = VALIDATED_CONFIG.get("genome_resources", {})

# Stage 55: reproducibility-driven IDR
REPRODUCIBILITY_CONFIG = VALIDATED_CONFIG.get("reproducibility", {})
REPRO_ENABLED = REPRODUCIBILITY_CONFIG.get("enabled", False)
ATAC_IDR_ENABLED = (
    REPRO_ENABLED
    and REPRODUCIBILITY_CONFIG.get("idr", {}).get("atac_narrow", False)
)

# Stage 62: consensus gating (reuses REPRO_ENABLED from Stage 55)
CONSENSUS_ENABLED = (
    REPRO_ENABLED
    and REPRODUCIBILITY_CONFIG.get("consensus", {}).get("enabled", True)
)

# Stage 7b: CUT&Tag peak caller config
CUTTAG_CONFIG = VALIDATED_CONFIG.get("cuttag", {})
SEACR_CFG = CUTTAG_CONFIG.get("seacr", {})
SEACR_ENABLED = (
    SEACR_CFG.get("enabled", False)
    if isinstance(SEACR_CFG, dict) else False
)
SEACR_MODE = str(SEACR_CFG.get("mode", "stringent"))
SEACR_NORMALIZATION = str(SEACR_CFG.get("normalization", "non"))
SEACR_THRESHOLD = float(SEACR_CFG.get("threshold", 0.01))

# ---------------------------------------------------------------------------
# 2. Helper functions
# ---------------------------------------------------------------------------

def _normalize_genome(genome):
    """Resolve effective genome size from genome_resources or legacy fallback.

    Prefers configured effective_genome_size in genome_resources.
    Falls back to legacy mm10/mm39 → mm, hg19/hg38 → hs mapping only
    when no resource entry exists for the genome.
    """
    resource = GENOME_RESOURCES.get(genome, {})
    egs = resource.get("effective_genome_size")
    if egs is not None and egs != "":
        return str(egs)

    # Legacy fallback — only when no genome_resource entry exists
    if genome in ("mm10", "mm39"):
        return "mm"
    if genome in ("hg19", "hg38"):
        return "hs"
    return genome


# ---------------------------------------------------------------------------
# 3. Sample sheet loading (validated via shared helpers)
# ---------------------------------------------------------------------------

SAMPLES = load_and_validate_samples(
    VALIDATED_CONFIG["samples"],
    use_control=USE_CONTROL,
    stage5_enabled=STAGE5,
    reproducibility_idr_atac_narrow=ATAC_IDR_ENABLED,
)

# Stage 12: reference_fasta gating for Picard metrics
validate_picard_reference_resources(VALIDATED_CONFIG, SAMPLES)
# Stage 18: GTF annotation gating for TSS enrichment profiles
validate_tss_annotation_resources(VALIDATED_CONFIG, SAMPLES)

# --- Derived ID lists ---
SAMPLE_MAP           = {s["id"]: s for s in SAMPLES}
ALL_SAMPLE_IDS       = [s["id"] for s in SAMPLES]
TREATMENT_SAMPLE_IDS = [
    s["id"] for s in SAMPLES if s["role"] == "treatment"
]
# use_control gates both FASTQ-based control_sample and external control_bam.
# When false, control rows are not required as rule-all targets and
# control_sample / control_bam are silently ignored.
ACTIVE_SAMPLE_IDS = (
    ALL_SAMPLE_IDS if USE_CONTROL else TREATMENT_SAMPLE_IDS
)
CONTROL_SAMPLE_IDS   = [
    s["id"] for s in SAMPLES if s["role"] == "control"
]
CUTTAG_ACTIVE_SAMPLE_IDS = [
    sid for sid in ACTIVE_SAMPLE_IDS
    if SAMPLE_MAP[sid]["assay"] == "cuttag"
]

# Stage 7b: SEACR sidecar sample list (CUT&Tag PE treatment only)
if SEACR_ENABLED:
    SEACR_SAMPLE_IDS = [
        sid for sid in TREATMENT_SAMPLE_IDS
        if SAMPLE_MAP[sid]["assay"] == "cuttag"
        and SAMPLE_MAP[sid]["layout"] == "PE"
    ]
else:
    SEACR_SAMPLE_IDS = []

# Stage 39: MNase-centric derived lists
MNASE_SAMPLE_IDS = [
    s["id"] for s in SAMPLES
    if s["role"] == "treatment" and s["assay"] == "mnase"
]

# Peak-centric treatment samples (all treatment samples that are NOT MNase)
PEAK_SAMPLE_IDS = [
    s["id"] for s in SAMPLES
    if s["role"] == "treatment" and s["assay"] != "mnase"
]

