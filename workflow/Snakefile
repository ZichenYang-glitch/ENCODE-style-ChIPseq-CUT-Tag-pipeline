configfile: "config/config.yaml"

VALIDATED_CONFIG = validate_config(config)

OUTDIR      = VALIDATED_CONFIG["outdir"]
THREADS     = VALIDATED_CONFIG["threads"]
MAPQ        = VALIDATED_CONFIG["mapq"]
MAPQ_TAG    = f"mapq{MAPQ}"
BINSIZE     = VALIDATED_CONFIG["binsize"]
