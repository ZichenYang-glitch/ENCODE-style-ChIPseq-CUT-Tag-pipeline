    "route": "star_salmon"
  },
  "tool_versions": {
    "fastp": "1.0.1",
    "fastqc": "0.12.1",
    "featurecounts": "2.0.6",
    "multiqc": "1.33",
    "picard": "3.4.0",
    "rseqc": "5.0.4",
    "salmon": "1.10.3",
    "star": "2.7.11b",
    "trimgalore": "2.1.0"
  },
  "artifact_families": [
    "fastqc_html_zip",
    "trimming_machine_reports",
    "saved_trimmed_reads",
    "saved_rrna_filtered_reads",
    "star_final_summary_and_junctions",
    "final_and_enabled_intermediate_bam_indexes",
    "combined_and_strand_specific_bigwig",
    "salmon_sample_quantification",
    "salmon_merged_expression_matrices",
    "featurecounts_biotype_qc",
    "enabled_rseqc_machine_summaries",
    "multiqc_allowlisted_module_tsv",
    "multiqc_trimmed_and_mapped_sample_status_tsv",
    "pipeline_software_versions"
  ],
  "qc_source_families": [
    "fastqc_zip",
    "fastp_json",
    "multiqc_cutadapt_tsv",
    "star_log_final",
    "salmon_meta_info",
    "featurecounts_summary",
    "multiqc_picard_dups_tsv",
    "multiqc_sample_status_tsv",
    "rseqc_bam_stat",
    "rseqc_infer_experiment",
    "rseqc_read_distribution",
    "rseqc_tin_summary"
  ],
  "metric_catalog": [
    {"prefix": "fastqc.<stage>.<read_role>", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "trimming", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "star", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "salmon", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "picard", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "featurecounts", "units": ["count", "fraction"], "scope": "sample"},
    {"prefix": "rseqc", "units": ["count", "fraction", "ratio", "score"], "scope": "sample"}
  ],
  "artifact_semantics": {
    "rseqc_inner_distance": {
      "distance": {
        "output_type": "bulk_rnaseq.rseqc.inner_distance.distance",
        "path": "star_salmon/rseqc/inner_distance/txt/<sample>.inner_distance.txt",
        "semantic": "per_read_pair_detail"
      },
      "frequency": {
        "output_type": "bulk_rnaseq.rseqc.inner_distance.freq",
        "path": "star_salmon/rseqc/inner_distance/txt/<sample>.inner_distance_freq.txt",
        "semantic": "insert_size_frequency"
      },
      "mean": {
        "output_type": "bulk_rnaseq.rseqc.inner_distance.mean",
        "path": "star_salmon/rseqc/inner_distance/txt/<sample>.inner_distance_mean.txt",
        "semantic": "mean_median_standard_deviation_summary"
      }
    }
  },
  "metric_semantics": {
    "salmon_meta_info": {
      "num_processed": {
        "metric_key": "salmon.processed_fragments",
        "display_name": "Salmon processed fragments",
        "semantic": "observed_fragments",
        "unit": "count"
      },
      "num_mapped": {
        "metric_key": "salmon.mapped_fragments",
        "display_name": "Salmon mapped fragments",
        "semantic": "mapped_fragments",
        "unit": "count"
      },
      "mapping_fraction": {
        "metric_key": "salmon.mapping_fraction",
        "display_name": "Salmon mapped fragment fraction",
        "semantic": "mapped_fragments_divided_by_processed_fragments",
        "unit": "fraction"
      },
      "paired_end_fragment": "one_read_pair",
      "single_end_fragment": "one_single_read"
    }
  },
  "upstream_behavior_evidence": {
    "rseqc_inner_distance": {
      "version": "5.0.4",
      "nfcore_module_path": "modules/nf-core/rseqc/innerdistance/main.nf",
      "nfcore_module_size": 1892,
      "nfcore_module_sha256": "7450e476b2bd4def87904e202e131c8cc675c9ded4860ec55720f799711165cc"
    },
    "rseqc_tin": {
      "version": "5.0.4",
      "behavior": "tin.py applies a case-sensitive global basename.replace('bam', '') while the pinned nf-core wrapper expects bam.baseName outputs",
      "package_sha256": "2efb38bf459257693abfc952b0557be862a780240e8a49f3a4f90362b6645ca6"
    },
    "salmon_meta_info": {
      "version": "1.10.3",
      "behavior": "num_processed and num_mapped are emitted from numObservedFragments and numMappedFragments",
      "audited_source_path": "src/GZipWriter.cpp",
      "audited_source_sha256": "7880e0b8c8f5313eeb7486f21d08b9cefe279ec2447d602a94ec6a0497f64d5a"
    }
  },
  "public_exclusions": [
    {"path": "multiqc/star_salmon/multiqc_report.html", "reason": "MultiQC 1.33 embeds analysis-file paths unless a future pinned runtime gate proves a privacy override"},
    {"path": "multiqc/star_salmon/multiqc_report_data/multiqc_data.json", "reason": "contains command and absolute path fields"},
    {"path": "multiqc/star_salmon/multiqc_report_data/multiqc_sources.txt", "reason": "contains source paths"},
    {"path": "multiqc/star_salmon/multiqc_report_data/multiqc.log", "reason": "contains execution-private diagnostics"},
    {"path": "multiqc/star_salmon/multiqc_report_data/multiqc.parquet", "reason": "unbounded dynamic schema"},
    {"path": "multiqc/star_salmon/multiqc_report_data/llms-full.txt", "reason": "unbounded generated report text"},
    {"path": "star_salmon/<sample>/cmd_info.json", "reason": "contains invocation details"},
    {"path": "star_salmon/<sample>/logs/salmon_quant.log", "reason": "contains execution-private diagnostics"},
    {"path": "trimgalore/*_trimming_report.txt", "reason": "contains command-line parameters and input filename fields"},
    {"path": "fastp/<sample>.fastp.html", "reason": "HTML content is not covered by the fixed machine-data privacy audit"},
    {"path": "fastp/log/<sample>.fastp.log", "reason": "contains invocation diagnostics"},
    {"path": "sortmerna/<sample>.sortmerna.log", "reason": "contains staged database and execution diagnostics"},
    {"path": "bowtie2_rrna/<sample>.bowtie2_rrna.bowtie2.log", "reason": "contains staged database and execution diagnostics"},
    {"path": "star_salmon/samtools_stats/<sample>.*.bam.stats", "reason": "contains a samtools command line"},
    {"path": "star_salmon/featurecounts/<sample>.featureCounts.tsv", "reason": "contains the featureCounts command and staged paths"},
    {"path": "star_salmon/salmon.merged.{gene,transcript}.SummarizedExperiment.rds", "reason": "opaque serialized R object is outside the audited public contract"},
    {"path": "star_salmon/picard_metrics/*", "reason": "raw Picard metrics may contain command and staged-path headers"},
    {"path": "star_salmon/deseq2_qc/*sessionInfo*", "reason": "contains execution environment details"},
    {"path": "**/*.{R,r,log}", "reason": "unreviewed generated scripts and raw logs are not public artifacts"},
    {"path": "star_salmon/log/<sample>.Log.out", "reason": "contains command and path details"},
    {"path": "pipeline_info/params_<timestamp>.json", "reason": "nondeterministic name and absolute input paths"},
    {"path": "pipeline_info/samplesheet.valid.csv", "reason": "contains absolute input paths"},
    {"path": "workspace/logs/nextflow.log", "reason": "outside results root and contains private runtime state"},
    {"path": "workspace/reports/*", "reason": "outside results root and contains private runtime state"}
  ],
  "explicit_profile_policy": {
    "save_reference": "fail_closed_until_exact_reference_tree_manifest",
    "stringtie": "fail_closed_until_complete_ballgown_and_merge_catalog",
    "qualimap": "excluded_unbounded_html_asset_tree",
    "dupradar": "excluded_non_core_plot_family",
    "deseq2_qc": "excluded_qc_visualization_not_differential_expression",
    "preseq": "excluded_non_core_optional_plot_family",
    "trimgalore_metrics": "trimmed_fastqc_total_sequences_is_exact_final_retained_reads; multiqc_cutadapt_integer_fields_describe_pre_length_filter_bases; exact_final_retained_bases_require_a_future_sanitized_derivative",
    "sample_threshold_filtering": "fixed_multiqc_status_tables define filtered samples; equality with min_trimmed_reads remains execution-passing; without MultiQC an ambiguous missing threshold-sensitive output fails with sample_status_unavailable",
    "umi_discard_read_layout": "a discarded mate makes the post-extraction route single-end while raw FastQC and saved UMI-extracted reads retain the authored paired layout",
    "rseqc_csi": "inner_distance, read_distribution, and tin are removed exactly as defineQcTools does for bam_csi_index",
    "multiqc_sample_identity": "sample identifiers containing any of the 159 identifier-alphabet literals cleaned by MultiQC 1.33 defaults or the pinned nf-core config are reserved; when MultiQC is enabled, canonical IDs, authored-PE aliases, effective downstream aliases, and FASTQ simpleNames after prepended extra_fn_clean_exts, default fn_clean_exts, fn_clean_trim, and global exact replacement must have one sample-and-mate-role owner before execution",
    "rseqc_tin_sample_identity": "effective TIN rejects case-sensitive lowercase bam in sample IDs before workspace planning; authored IDs are never rewritten"
  },
  "multiqc_sample_identity_sources": {
    "multiqc_version": "1.33",
    "multiqc_package_sha256": "06e2b82fd9bfa458a79d8da869cb7d88260f624c03297120a70446a49ce852ed",
    "multiqc_config_defaults_sha256": "037598900d99fb4a5a32aeea2afffa4702fb2b4c309a05819fd5b1c655ca55de",
    "filename_cleaning_order": "prepended_extra_fn_clean_exts_then_default_fn_clean_exts_then_fn_clean_trim_then_global_exact_name_replacement",
    "fn_clean_trim_count": 26,
    "nfcore_multiqc_config_path": "workflows/rnaseq/assets/multiqc/multiqc_config.yml",
    "nfcore_multiqc_config_size": 8940,
    "nfcore_multiqc_config_sha256": "d859d137f2aa7800f7e12a84dec6658b1f558197e08f3041d05cd69fa6aa0b7e"
  },
  "bounded_limits": {
    "artifact_candidates": 128128,
    "audited_namespace_entries": 128128,
    "sample_status_table_bytes": 194128,
    "qc_source_files": 16016,
    "qc_source_bytes_each": 16777216,
    "qc_source_bytes_total": 268435456,
    "qc_metrics": 128000,
    "json_depth": 16,
    "json_nodes": 50000,
    "json_string_characters": 8192
  },
  "determinism": {
    "artifact_sort": ["output_type", "relative_path"],
    "metric_sort": ["metric_key", "scope", "sample_id", "experiment_id", "source_artifact_id"],
    "numeric_type": "decimal",
    "percentage_conversion": "decimal_percent_divided_by_100",
    "unknown_output_policy": "ignore outside audited namespaces; reject foreign sample identity inside audited namespaces",
    "missing_required_policy": "fail_closed"
  }
}
