Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/macs3.lock /opt/pipeline/workflow/envs/macs3.lock

%post
    conda create -n chipseq-macs3 --file /opt/pipeline/workflow/envs/macs3.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-macs3/bin:$PATH
