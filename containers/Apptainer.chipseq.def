Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/chipseq.yml /opt/pipeline/workflow/envs/chipseq.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/chipseq.yml -n chipseq -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq/bin:$PATH
