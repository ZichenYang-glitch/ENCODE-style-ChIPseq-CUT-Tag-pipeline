Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/chipseq.lock /opt/pipeline/workflow/envs/chipseq.lock

%post
    conda create -n chipseq --file /opt/pipeline/workflow/envs/chipseq.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq/bin:$PATH
