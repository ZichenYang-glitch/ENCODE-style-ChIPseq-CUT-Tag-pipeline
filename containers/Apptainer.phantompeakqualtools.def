Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/phantompeakqualtools.yml /opt/pipeline/workflow/envs/phantompeakqualtools.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/phantompeakqualtools.yml -n chipseq-phantompeakqualtools -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-phantompeakqualtools/bin:$PATH
