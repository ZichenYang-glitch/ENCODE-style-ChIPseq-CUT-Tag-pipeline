Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/idr.lock /opt/pipeline/workflow/envs/idr.lock

%post
    conda create -n chipseq-idr --file /opt/pipeline/workflow/envs/idr.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-idr/bin:$PATH
