Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/idr.yml /opt/pipeline/workflow/envs/idr.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/idr.yml -n chipseq-idr -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-idr/bin:$PATH
