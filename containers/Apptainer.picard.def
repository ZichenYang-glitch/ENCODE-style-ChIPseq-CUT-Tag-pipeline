Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/picard.lock /opt/pipeline/workflow/envs/picard.lock

%post
    conda create -n chipseq-picard --file /opt/pipeline/workflow/envs/picard.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-picard/bin:$PATH
