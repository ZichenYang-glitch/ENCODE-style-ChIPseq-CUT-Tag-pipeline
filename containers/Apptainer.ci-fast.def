Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/ci-fast.yml /opt/pipeline/workflow/envs/ci-fast.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/ci-fast.yml -n ci-fast -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/ci-fast/bin:$PATH
