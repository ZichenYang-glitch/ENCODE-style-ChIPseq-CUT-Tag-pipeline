Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/fastqc.yml /opt/pipeline/workflow/envs/fastqc.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/fastqc.yml -n chipseq-fastqc -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-fastqc/bin:$PATH
