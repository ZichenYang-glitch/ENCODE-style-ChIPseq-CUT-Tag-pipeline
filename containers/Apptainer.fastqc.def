Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/fastqc.lock /opt/pipeline/workflow/envs/fastqc.lock

%post
    conda create -n chipseq-fastqc --file /opt/pipeline/workflow/envs/fastqc.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-fastqc/bin:$PATH
