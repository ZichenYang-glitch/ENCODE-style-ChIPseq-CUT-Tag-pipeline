Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/runner.lock /opt/pipeline/workflow/envs/runner.lock

%post
    conda create -n chipseq-runner --file /opt/pipeline/workflow/envs/runner.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-runner/bin:$PATH

%runscript
    exec snakemake "$@"
