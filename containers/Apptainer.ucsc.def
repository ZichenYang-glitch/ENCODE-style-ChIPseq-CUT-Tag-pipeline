Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/ucsc.yml /opt/pipeline/workflow/envs/ucsc.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/ucsc.yml -n chipseq-ucsc -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-ucsc/bin:$PATH
