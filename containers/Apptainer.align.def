Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/align.lock /opt/pipeline/workflow/envs/align.lock

%post
    conda create -n chipseq-align --file /opt/pipeline/workflow/envs/align.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-align/bin:$PATH
