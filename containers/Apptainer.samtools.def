Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/samtools.lock /opt/pipeline/workflow/envs/samtools.lock

%post
    conda create -n chipseq-samtools --file /opt/pipeline/workflow/envs/samtools.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-samtools/bin:$PATH
