Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/preseq.yml /opt/pipeline/workflow/envs/preseq.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/preseq.yml -n chipseq-preseq -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-preseq/bin:$PATH
