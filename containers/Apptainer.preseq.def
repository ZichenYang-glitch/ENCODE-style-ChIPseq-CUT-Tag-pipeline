Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/preseq.lock /opt/pipeline/workflow/envs/preseq.lock

%post
    conda create -n chipseq-preseq --file /opt/pipeline/workflow/envs/preseq.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-preseq/bin:$PATH
