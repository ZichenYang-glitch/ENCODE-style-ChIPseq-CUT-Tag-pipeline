Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/multiqc.yml /opt/pipeline/workflow/envs/multiqc.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/multiqc.yml -n chipseq-multiqc -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-multiqc/bin:$PATH
