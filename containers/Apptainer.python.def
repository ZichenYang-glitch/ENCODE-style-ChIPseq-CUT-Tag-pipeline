Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/python.yml /opt/pipeline/workflow/envs/python.yml

%post
    conda env create -f /opt/pipeline/workflow/envs/python.yml -n chipseq-python -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-python/bin:$PATH
