Bootstrap: docker
From: condaforge/miniforge3:24.11.3-0

%files
    workflow/envs/deeptools.lock /opt/pipeline/workflow/envs/deeptools.lock

%post
    conda create -n chipseq-deeptools --file /opt/pipeline/workflow/envs/deeptools.lock -y
    conda clean -afy

%environment
    export PATH=/opt/conda/envs/chipseq-deeptools/bin:$PATH
